# Copy to .env. Both of these are optional - the app works fully without either.
# Build with: flutter run --dart-define-from-file=.env

# Only used for the ONE-TIME legacy-account cloud import at onboarding. Leave
# blank if you don't have an old cloud account to pull history from - the app
# is otherwise fully local, this isn't an ongoing backend dependency.
BACKEND_URL=https://your-backend.example.workers.dev

# Only used for the OTA/announcement pointer and the BYOK LLM proxy. Leave
# blank to skip both (see lib/cloud/companion_client.dart).
COMPANION_URL=https://your-companion.example.workers.dev
